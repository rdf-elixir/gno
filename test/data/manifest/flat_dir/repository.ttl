@prefix gno: <https://w3id.org/gno#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .

<http://example.com/Repository> a gno:Repository ;
    gno:repositoryDataset <http://example.com/Dataset> .

<http://example.com/Dataset> a gno:Dataset ;
    dcterms:title "test dataset" .

