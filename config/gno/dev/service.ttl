@prefix dcatr: <https://w3id.org/dcatr#> .
@prefix gno: <https://w3id.org/gno#> .
@prefix gnoa: <https://w3id.org/gno/store/adapter/> .
@prefix dcterms: <http://purl.org/dc/terms/> .

<Service> a gno:Service
    ; dcatr:serviceRepository <Repository>
    ; gno:serviceStore <Fuseki>
#    ; gno:serviceStore <Oxigraph>
#    ; gno:serviceStore <Qlever>
#    ; gno:serviceStore <GraphDB>
#    ; gno:serviceStore <GenericStore>
    ; dcterms:title "dev service"
    ; dcterms:creator <User>
    ; dcterms:publisher <User>
.

<GenericStore> a gno:Store
    # Fuseki
    ; gno:storeQueryEndpoint <http://localhost:3030/gno-dev-dataset/query>
    ; gno:storeUpdateEndpoint <http://localhost:3030/gno-dev-dataset/update>
    ; gno:storeGraphStoreEndpoint <http://localhost:3030/gno-dev-dataset/data>

    # Oxigraph
#    ; gno:storeQueryEndpoint <http://localhost:7878/query>
#    ; gno:storeUpdateEndpoint <http://localhost:7878/update>
#    ; gno:storeGraphStoreEndpoint <http://localhost:7878/store>
.

<Fuseki> a gnoa:Fuseki
    ; gno:storeEndpointScheme "http"
    ; gno:storeEndpointHost "localhost"
    ; gno:storeEndpointPort 3030
    ; gno:storeEndpointDataset "gno-dev-dataset"
.

<Oxigraph> a gnoa:Oxigraph
    # all of these can be omitted since predefined defaults of the adapter
    ; gno:storeEndpointScheme "http"
    ; gno:storeEndpointHost "localhost"
    ; gno:storeEndpointPort 7878
.

<Qlever> a gnoa:Qlever
    ; gno:storeEndpointPort 7001
    ; gnoa:qleverAccessToken "gno-dev-token"
.

<GraphDB> a gnoa:GraphDB
    ; gno:storeEndpointDataset "gno-dev-repository"
    ; gno:storeEndpointPort 7200
.
