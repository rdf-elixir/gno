@prefix gno: <https://w3id.org/gno#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

<Repository> a gno:Repository
    ; gno:repositoryDataset <Dataset>
    ; dcterms:title "dev repository"
    ; dcterms:creator <User>
    ; dcterms:publisher <User>
.

<Dataset> a gno:Dataset
    ; dcterms:title "dev dataset"
    ; dcterms:creator <User>
    ; dcterms:publisher <User>
.
