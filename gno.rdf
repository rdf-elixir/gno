    <rdfs:label>Manifest</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/gno#Manifest">
    <rdfs:comment>A manifest document that describes a Gno service configuration, including repository and store settings.</rdfs:comment>
